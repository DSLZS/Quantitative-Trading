# ===========================================
# Python Quantitative Trading System .gitignore
# Security Isolation Configuration
# ===========================================

# -------------------------------------------
# Python
# -------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# -------------------------------------------
# Virtual Environment
# -------------------------------------------
venv/
ENV/
env/
.venv/

# -------------------------------------------
# IDE
# -------------------------------------------
.idea/
*.iml
*.ipr
*.iws
.vscode/
*.code-workspace
.ipynb_checkpoints/
.spyderproject
.spyproject

# -------------------------------------------
# Testing
# -------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# -------------------------------------------
# Type Checkers
# -------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/

# -------------------------------------------
# SENSITIVE CONFIGURATION (安全隔离 - 敏感配置)
# -------------------------------------------
# 配置文件（仅允许 .example 模板上传）
config/settings.yaml
!config/settings.yaml.example

# 环境变量文件（包含 API Key、数据库密码等）
.env
.env.local
.env.*.local
.env.*

# 凭证文件
*-credentials.json
credentials.json
*.pem
*.key

# -------------------------------------------
# LOCAL DATA FILES (本地数据 - 禁止上传)
# -------------------------------------------
# Database files
*.db
*.sqlite
*.sqlite3

# Parquet files (generated data)
data/**/*.parquet
data/*.parquet

# CSV files (generated data)
data/**/*.csv
data/*.csv

# Feather files
data/**/*.feather
data/*.feather

# Pickle and joblib files
*.pkl
*.joblib

# -------------------------------------------
# MODEL FILES (模型文件 - 可重新生成)
# -------------------------------------------
data/models/*
!data/models/.gitkeep

# -------------------------------------------
# PLOTS AND VISUALIZATIONS (图表输出)
# -------------------------------------------
data/plots/
!data/plots/.gitkeep

# -------------------------------------------
# LOG FILES (日志文件)
# -------------------------------------------
logs/
*.log
logs/*.log

# -------------------------------------------
# SYNC STATUS (数据同步状态)
# -------------------------------------------
data/sync_status/*
!data/sync_status/.gitkeep

# -------------------------------------------
# CACHE (缓存文件)
# -------------------------------------------
data/cache/
data/.cache/

# -------------------------------------------
# DOCUMENTATION BUILD (文档构建)
# -------------------------------------------
docs/_build/
docs/build/

# -------------------------------------------
# OS FILES (系统文件)
# -------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# -------------------------------------------
# LOCAL OVERRIDES (本地覆盖配置)
# -------------------------------------------
*.local
*.override