# ===========================================
# Python Quantitative Trading System .gitignore
# ===========================================

# -------------------------------------------
# Python
# -------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# -------------------------------------------
# Virtual Environment
# -------------------------------------------
venv/
ENV/
env/
.venv/

# -------------------------------------------
# IDE
# -------------------------------------------
# PyCharm
.idea/
*.iml
*.ipr
*.iws

# VS Code
.vscode/
*.code-workspace

# Jupyter Notebook
.ipynb_checkpoints/

# Spyder
.spyderproject
.spyproject

# -------------------------------------------
# Project Specific - Sensitive Files
# -------------------------------------------
# Environment variables (contains passwords/tokens)
.env
.env.local
.env.*.local

# Database credentials
*-credentials.json
credentials.json

# -------------------------------------------
# Project Specific - Data Files
# -------------------------------------------
# Database files (if using SQLite locally)
*.db
*.sqlite
*.sqlite3

# Large data files (should use Git LFS or DVC)
data/*.csv
data/*.parquet
data/*.feather
data/raw/*
!data/raw/.gitkeep
data/parquet/*
!data/parquet/.gitkeep

# Model files (large binary files)
data/models/*.txt
data/models/*.pkl
data/models/*.joblib
data/models/*.bin
!data/models/.gitkeep

# -------------------------------------------
# Project Specific - Logs
# -------------------------------------------
logs/
*.log

# -------------------------------------------
# Project Specific - OS
# -------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# -------------------------------------------
# Testing
# -------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# -------------------------------------------
# Jupyter
# -------------------------------------------
.ipynb_checkpoints

# -------------------------------------------
# mypy
# -------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json

# -------------------------------------------
# Pyre type checker
# -------------------------------------------
.pyre/

# -------------------------------------------
# Notes (optional - uncomment to ignore)
# -------------------------------------------
# *.md
# notes/